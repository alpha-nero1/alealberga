---
const currentYear = new Date().getFullYear();
const messages = [
	"Let's change the world together.",
	'Ready to get cooking?',
	"I'm excited to hear from you.",
	"Ready when you are!",
	"Got a challenging project? Music to my ears.",
];
const message = messages[Math.floor(Math.random() * messages.length)];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&family=Fraunces:opsz,wght@9..144,500;9..144,700&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/svg+xml" href="/me.svg" />
		<link rel="icon" href="/me.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Ale Alberga</title>
	</head>
	<body>
		<header class="site-header">
			<nav class="site-nav" aria-label="Primary">
				<a class="brand" href="/#home">Ale Alberga</a>
				<input id="menu-toggle" class="menu-toggle" type="checkbox" aria-label="Toggle navigation menu" />
				<label for="menu-toggle" class="menu-button" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</label>
				<div class="nav-links" id="primary-links">
					<a href="/#craft">Craft</a>
					<a href="/#toolkit">Toolkit</a>
					<a href="/#impact">Impact</a>
					<a href="/#reputation">Reputation</a>
					<a href="/#now">Now</a>
					<a href="/#growth">Growth</a>
					<a href="/blogs">Blogs</a>
					<a class="nav-cta mobile-cta" href="/#growth">Let's Connect</a>
				</div>
				<a class="nav-cta" href="/#growth">Let's Connect</a>
			</nav>
		</header>
		<slot />
		<footer class="site-footer">
			<div class="footer-shell">
				<div class="footer-copy">
					<p class="footer-title">{message}</p>
					<p class="footer-meta">© {currentYear} Ale Alberga.</p>
				</div>
				<div class="footer-links" aria-label="Social links">
					<a href="https://github.com/alpha-nero1" target="_blank" rel="noreferrer">
						<span>GitHub</span>
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d="M12 2C6.477 2 2 6.589 2 12.248c0 4.526 2.865 8.364 6.839 9.719.5.095.682-.222.682-.494 0-.244-.009-.89-.014-1.747-2.782.617-3.37-1.37-3.37-1.37-.455-1.177-1.11-1.49-1.11-1.49-.908-.637.069-.624.069-.624 1.004.072 1.532 1.053 1.532 1.053.892 1.57 2.341 1.116 2.91.853.091-.663.349-1.116.635-1.373-2.221-.259-4.555-1.137-4.555-5.061 0-1.118.389-2.033 1.027-2.75-.103-.26-.445-1.305.098-2.722 0 0 .838-.276 2.746 1.05A9.303 9.303 0 0 1 12 6.835a9.27 9.27 0 0 1 2.5.348c1.907-1.326 2.744-1.05 2.744-1.05.544 1.417.202 2.462.1 2.722.64.717 1.026 1.632 1.026 2.75 0 3.934-2.338 4.799-4.566 5.053.359.318.679.946.679 1.907 0 1.377-.012 2.487-.012 2.825 0 .275.18.594.688.493A10.25 10.25 0 0 0 22 12.248C22 6.589 17.523 2 12 2Z"/>
						</svg>
					</a>
					<a href="https://www.linkedin.com/in/alessandro-alberga-0a3b23117/" target="_blank" rel="noreferrer">
						<span>LinkedIn</span>
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 3C4.17 3 3.5 3.72 3.5 4.66c0 .92.65 1.66 1.71 1.66h.02c1.1 0 1.77-.74 1.77-1.66C6.98 3.72 6.34 3 5.25 3ZM20.5 12.91c0-3.07-1.64-4.5-3.83-4.5-1.77 0-2.56.98-3 1.67V8.5h-3.38c.04 1.04 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.68.12-.92.27-.68.87-1.38 1.88-1.38 1.33 0 1.87 1.04 1.87 2.56V20h3.38v-7.09Z"/>
						</svg>
					</a>
					<a href="https://x.com/your-username" target="_blank" rel="noreferrer">
						<span>X / Twitter</span>
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d="M18.244 2H21l-6.02 6.88L22 22h-5.48l-4.29-7.9L5.32 22H2.56l6.44-7.36L2 2h5.62l3.88 7.28L18.244 2Zm-.97 18.34h1.53L6.8 3.58H5.16l12.114 16.76Z"/>
						</svg>
					</a>
					<a href="mailto:ale.alberga1@gmail.com">
						<span>Email</span>
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d="M3 5.5A2.5 2.5 0 0 1 5.5 3h13A2.5 2.5 0 0 1 21 5.5v13a2.5 2.5 0 0 1-2.5 2.5h-13A2.5 2.5 0 0 1 3 18.5v-13Zm2.14-.5 6.86 5.72L18.86 5H5.14Zm14.36 1.3-6.86 5.7a1 1 0 0 1-1.28 0L4.5 6.3v12.2a.5.5 0 0 0 .5.5h14a.5.5 0 0 0 .5-.5V6.3Z"/>
						</svg>
					</a>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Plus Jakarta Sans', 'Trebuchet MS', sans-serif;
		background: #081426;
		color: #e6f1ff;
	}

	* {
		box-sizing: border-box;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		padding: 0.8rem min(2.3vw, 1.2rem);
		background: linear-gradient(180deg, rgba(3, 9, 20, 0.8) 0%, rgba(3, 9, 20, 0.52) 72%, transparent 100%);
		backdrop-filter: blur(8px);
	}

	.site-nav {
		width: min(980px, 100%);
		margin: 0 auto;
		padding: 0.65rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.7rem;
		border: 1px solid rgba(201, 221, 255, 0.2);
		border-radius: 999px;
		background: rgba(10, 26, 45, 0.72);
		box-shadow: 0 14px 30px rgba(2, 7, 20, 0.4);
	}

	.brand {
		padding: 0.44rem 0.75rem;
		font-family: 'Fraunces', Georgia, serif;
		font-size: 1.03rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: #e6f1ff;
		text-decoration: none;
	}

	.nav-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.25rem;
	}

	.menu-toggle {
		display: none;
	}

	.menu-button {
		display: none;
		width: 2.4rem;
		height: 2.4rem;
		border: 1px solid rgba(201, 221, 255, 0.28);
		border-radius: 0.85rem;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		gap: 0.24rem;
		cursor: pointer;
		background: rgba(13, 34, 57, 0.68);
	}

	.menu-button span {
		display: block;
		width: 1rem;
		height: 2px;
		border-radius: 99px;
		background: #d2e5ff;
		transition: transform 180ms ease, opacity 180ms ease;
	}

	.nav-links a,
	.nav-cta {
		padding: 0.42rem 0.72rem;
		border-radius: 999px;
		font-family: 'Plus Jakarta Sans', 'Trebuchet MS', sans-serif;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: #d2e5ff;
		text-decoration: none;
		white-space: nowrap;
		transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
	}

	.nav-links a:hover,
	.nav-links a:focus-visible,
	.nav-cta:hover,
	.nav-cta:focus-visible {
		background: rgba(79, 212, 196, 0.18);
		color: #f6fcff;
		transform: translateY(-1px);
		outline: none;
	}

	.nav-cta {
		background: linear-gradient(135deg, rgba(79, 212, 196, 0.22), rgba(242, 179, 111, 0.22));
		border: 1px solid rgba(79, 212, 196, 0.34);
	}

	.mobile-cta {
		display: none;
	}

	.site-footer {
		margin-top: 1.2rem;
		padding: 1rem min(2.3vw, 1.2rem) 2.1rem;
		background: linear-gradient(180deg, rgba(8, 20, 38, 0) 0%, rgba(8, 20, 38, 0.74) 34%, rgba(8, 20, 38, 1) 100%);
	}

	.footer-shell {
		width: min(980px, 100%);
		margin: 0 auto;
		padding: 1.2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border: 1px solid rgba(201, 221, 255, 0.28);
		border-radius: 20px;
		background:
			radial-gradient(circle at 12% 0%, rgba(242, 179, 111, 0.14), transparent 35%),
			radial-gradient(circle at 90% 100%, rgba(79, 212, 196, 0.14), transparent 35%),
			rgba(10, 26, 45, 0.86);
		box-shadow: 0 20px 45px rgba(2, 7, 20, 0.52);
		backdrop-filter: blur(8px);
	}

	.footer-title,
	.footer-meta {
		margin: 0;
	}

	.footer-title {
		font-family: 'Fraunces', Georgia, serif;
		font-size: clamp(1.02rem, 1.9vw, 1.24rem);
		color: #e6f1ff;
	}

	.footer-meta {
		margin-top: 0.3rem;
		font-family: 'Plus Jakarta Sans', 'Trebuchet MS', sans-serif;
		font-size: 0.85rem;
		color: #9eb6da;
	}

	.footer-links {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.footer-links a {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.45rem 0.72rem;
		border-radius: 999px;
		border: 1px solid rgba(201, 221, 255, 0.2);
		background: rgba(16, 40, 68, 0.78);
		font-family: 'Plus Jakarta Sans', 'Trebuchet MS', sans-serif;
		font-size: 0.8rem;
		font-weight: 700;
		color: #d2e5ff;
		text-decoration: none;
		transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
	}

	.footer-links svg {
		width: 0.95rem;
		height: 0.95rem;
		flex: 0 0 auto;
	}

	.footer-links a:hover,
	.footer-links a:focus-visible {
		background: rgba(79, 212, 196, 0.2);
		color: #f6fcff;
		transform: translateY(-1px);
		outline: none;
	}

	@media (max-width: 900px) {
		.site-nav {
			position: relative;
			border-radius: 20px;
			padding: 0.55rem;
			flex-wrap: nowrap;
			justify-content: space-between;
		}

		.brand {
			width: auto;
		}

		.menu-button {
			display: flex;
		}

		.nav-links {
			display: none;
			position: absolute;
			top: calc(100% + 0.5rem);
			right: 0;
			left: 0;
			padding: 0.55rem;
			border: 1px solid rgba(201, 221, 255, 0.22);
			border-radius: 16px;
			background: rgba(10, 26, 45, 0.95);
			box-shadow: 0 16px 40px rgba(2, 7, 20, 0.6);
			flex-direction: column;
			align-items: stretch;
			gap: 0.3rem;
		}

		.nav-links a,
		.mobile-cta {
			width: 100%;
			text-align: left;
		}

		.mobile-cta {
			display: block;
		}

		.nav-cta {
			display: none;
		}

		.menu-toggle:checked ~ .nav-links {
			display: flex;
		}

		.menu-toggle:checked + .menu-button span:nth-child(1) {
			transform: translateY(6px) rotate(45deg);
		}

		.menu-toggle:checked + .menu-button span:nth-child(2) {
			opacity: 0;
		}

		.menu-toggle:checked + .menu-button span:nth-child(3) {
			transform: translateY(-6px) rotate(-45deg);
		}

		.footer-shell {
			padding: 1rem;
			flex-direction: column;
			align-items: flex-start;
		}

		.footer-links {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>
